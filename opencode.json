{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["uvx", "mcp-nixos"]
    },
    "home-assistant": {
      "type": "remote",
      "url": "https://home.thisratis.gay/api/mcp",
      "headers": {
        "Authorization": "Bearer {env:HOME_ASSISTANT_TOKEN}"
      },
      "oauth": false
    }
  },
  "permission": {
    "external_directory": {
      "~/Development/nixpkgs/**": "allow",
      "~/Development/home-manager/**": "allow",
      "/nix/store/**": "allow"
    }
  }
}
